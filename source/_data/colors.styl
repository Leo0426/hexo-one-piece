:root {
  --grey-0: #fff;
  --grey-1: #f7fbff;
  --grey-2: #eef7fc;
  --grey-3: #d8edf8;
  --grey-4: #b7ccd8;
  --grey-5: #6f8796;
  --grey-6: #425d6c;
  --grey-7: #263f4d;
  --grey-8: #102b3a;
  --grey-9: #071923;

  --grey-1-a0: alpha(#f7fbff, 0);
  --grey-1-a7: alpha(#f7fbff, .7);
  --grey-1-a5: alpha(#f7fbff, .5);
  --grey-1-a3: alpha(#f7fbff, .3);
  --grey-9-a1: alpha(#071923, .12);
  --grey-9-a5: alpha(#071923, .52);
  --grey-2-a0: alpha(#eef7fc, 0);

  --color-pink-light: #fff1ec;
  --color-cyan-light: #e7f8ff;

  --color-red: #d92d20;
  --color-pink: #e84b3c;
  --color-orange: #f28c28;
  --color-yellow: #f6c445;
  --color-green: #2e8b57;
  --color-aqua: #00a6c8;
  --color-blue: #1677c7;
  --color-purple: #7c4d8a;
  --color-grey: #6f8796;

  --color-red-a1: alpha(#d92d20, .1);
  --color-red-a3: alpha(#d92d20, .3);
  --color-pink-a3: alpha(#e84b3c, .3);
  --color-pink-light-a3: alpha(#fff1ec, .3);
  --color-pink-light-a5: alpha(#fff1ec, .5);
  --color-pink-light-a7: alpha(#fff1ec, .7);

  --body-bg-shadow: var(--grey-2);
  --box-bg-shadow: var(--grey-9-a1);
  --text-color: var(--grey-7);
  --header-text-color: var(--grey-0);
  --primary-color: var(--color-red);

  --nav-bg: linear-gradient(135deg, #0f7fc7 0, #00a6c8 52%, #f6c445 100%);

}

.primary {
  --note-border: #f0a29a;
  --note-bg: #fff4f1;
  --note-text: #b42318;
  --note-hover: #d92d20;
}

.info {
  --note-border: #8bd8e8;
  --note-bg: #eefbff;
  --note-text: #0f6f8f;
  --note-hover: #00a6c8;
}

.success {
  --note-border: #97d8c4;
  --note-bg: #f0fff9;
  --note-text: #1f7a57;
  --note-hover: #29936f;
}

.warning {
  --note-border: #f3d36b;
  --note-bg: #fff9df;
  --note-text: #8a5a00;
  --note-hover: #c78a00;
}

.danger {
  --note-border: #ffafa6;
  --note-bg: #fff0ed;
  --note-text: #b42318;
  --note-hover: #e84b3c;
}

[data-theme="dark"] {
  &:root {
    --grey-0: #0b1220;
    --grey-1: #101923;
    --grey-2: #142033;
    --grey-3: #1b2c40;
    --grey-4: #375167;
    --grey-5: #8aa1b2;
    --grey-6: #b8c9d5;
    --grey-7: #dbe7ef;
    --grey-8: #edf6fb;
    --grey-9: #fff;

    --grey-1-a7: alpha(#101923, .7);
    --grey-1-a5: alpha(#101923, .5);
    --grey-1-a3: alpha(#101923, .3);
    --grey-1-a0: alpha(#101923, 0);
    --grey-9-a1: alpha(#000, .25);
    --grey-9-a5: alpha(#000, .55);
    --grey-2-a0: alpha(#142033, 0);

    --color-pink-light: #2b171c;
    --color-cyan-light: #102b3a;

    --color-red: #ff6b5d;
    --color-pink: #ff8a78;
    --color-orange: #f59e0b;
    --color-yellow: #ffd166;
    --color-green: #73d39c;
    --color-aqua: #4dd0e1;
    --color-blue: #60a5fa;
    --color-purple: #c084fc;
    --color-grey: #9fb3c3;

    --color-red-a1: alpha(#ff6b5d, .14);
    --color-red-a3: alpha(#ff6b5d, .34);
    --color-pink-a3: alpha(#ff8a78, .34);
    --color-pink-light-a3: alpha(#2b171c, .3);
    --color-pink-light-a5: alpha(#2b171c, .5);
    --color-pink-light-a7: alpha(#2b171c, .7);

    --body-bg-shadow: #0b1220;
    --box-bg-shadow: alpha(#000, .45);
    --text-color: var(--grey-7);
    --header-text-color: var(--grey-9);
    --primary-color: var(--color-red);

    --nav-bg: linear-gradient(135deg, #061826 0, #0b3148 58%, #6b4a0b 100%);
  }

  .primary {
    --note-border: alpha(#ff6b5d, .55);
    --note-bg: alpha(#2a1515, .86);
    --note-text: #ffb4aa;
    --note-hover: alpha(#ff6b5d, .38);
  }

  .info {
    --note-border: alpha(#4dd0e1, .55);
    --note-bg: alpha(#0b3148, .82);
    --note-text: #b8f2fb;
    --note-hover: alpha(#4dd0e1, .32);
  }

  .success {
    --note-border: alpha(#73d39c, .5);
    --note-bg: alpha(#10291e, .82);
    --note-text: #b9f6d0;
    --note-hover: alpha(#73d39c, .3);
  }

  .warning {
    --note-border: alpha(#ffd166, .58);
    --note-bg: alpha(#32270b, .84);
    --note-text: #ffe6a3;
    --note-hover: alpha(#ffd166, .32);
  }

  .danger {
    --note-border: alpha(#ff8a78, .58);
    --note-bg: alpha(#351713, .86);
    --note-text: #ffd0c9;
    --note-hover: alpha(#ff8a78, .36);
  }

  .sidebar .tab li,
  .overview .menu .item,
  .index.wrap .card .message .btn,
  img, [data-background-image] {
    the-transition();
    opacity: .75;

    &:hover {
      opacity: .9;
    }
  }

  #imgs::before {
    background-color: rgba(0, 0, 0, 0.5);
  }
}

.red {
  color: var(--color-red);
}
.pink {
  color: var(--color-pink);
}
.orange {
  color: var(--color-orange);
}
.yellow {
  color: var(--color-yellow);
}
.green {
  color: var(--color-green);
}
.aqua {
  color: var(--color-aqua);
}
.blue {
  color: var(--color-blue);
}
.purple {
  color: var(--color-purple);
}
.grey {
  color: var(--color-grey);
}
