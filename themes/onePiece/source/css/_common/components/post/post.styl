.post.block {
  padding: 0 2rem 1.5rem;

  +mobile() {
    padding: 0 1.25rem 1rem;
  }

  .body.md {
    max-width: 52rem;
    margin: 0 auto;
    font-size: 1.0625rem;
    line-height: 1.95;
  }
}

.md {
  font-family: $font-family-posts;
  word-wrap();

  .exturl .ic {
    font-size: $font-size-small;
    margin-left: .25rem;
  }

  .button {
    margin-top: 2.5rem;
    text-align: center;
  }
}


@import 'breadcrumb';
@import 'header';
@import 'nav';
@import 'expand';
@import 'rtl';
@import 'footer';
@import 'tags';
@import 'reward';
@import 'copyright';
