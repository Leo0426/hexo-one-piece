.breadcrumb {
  display: inline-flex;
  font-size: 1.125rem;
  align-items: center;
  margin: 1.35rem 0;
  flex-wrap: wrap;
  gap: .2rem;

  a,
  span {
    font-family: "ZCOOL KuaiLe", "ZCOOL QingKe HuangYou", "Noto Serif SC", "PingFang SC", "Microsoft YaHei", sans-serif;
    font-weight: 400;
    font-synthesis: none;
    letter-spacing: .02rem;
  }

  .ic {
    margin: 0 .25rem;
    color: var(--grey-4);
    font-size: 1.05em;

    &:nth-child(1) {
      margin-left: 0rem;
      margin-right: .45rem;
    }
  }

  .breadcrumb__home-icon {
    background: url('../images/op-text-icons/sunny-emblem.png') center / contain no-repeat;
    height: 1.6em;
    width: 1.6em;

    &:before {
      content: '';
    }
  }

  span {
    white-space: pre;
  }

  span.current {
    background-color: var(--color-red-a1);
    border-radius: .75rem;
    padding: .25rem .85rem;
    the-transition();

    span {
      white-space: normal;
    }
    a {
      color: var(--primary-color);
    }

    &:hover {
      background-color: var(--color-red-a3);
    }
  }
}
