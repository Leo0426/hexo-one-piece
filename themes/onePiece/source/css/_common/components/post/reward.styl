.reward {
  margin: 1.25rem auto;
  padding: .625rem 0;
  text-align: center;

  button {
    background: var(--primary-color);
    border: 0;
    border-radius: .3125rem;
    color: var(--grey-0);
    cursor: pointer;
    line-height: 2;
    outline: 0;
    padding: 0 .9375rem;
    vertical-align: text-top;

    &:hover {
      background: var(--primary-color);
    }

    i {
      margin-right: .3125rem;
    }
  }

  p {
    font-size: $font-size-smaller;
    color: var(--grey-5);
    margin: 0;
  }
}

#qr {
  padding-top: 1.25rem;
  display: none;
  gap: 1.25rem;
  justify-content: center;
  align-items: flex-start;
  flex-wrap: wrap;

  a {
    border: 0;
  }

  > div {
    width: 15.5rem;
  }

  img {
    display: block;
    width: 100%;
    height: 15.5rem;
    padding: .625rem;
    border: .0625rem solid var(--grey-4);
    border-radius: .75rem;
    background: var(--grey-0);
    object-fit: contain;
    object-position: center;
    box-shadow: 0 .5rem 1.1rem -.75rem var(--grey-9-a1);
  }

  +mobile() {
    > div {
      width: 13rem;
    }

    img {
      height: 13rem;
    }
  }

  p {
    text-align: center;
    margin-top: .5rem;
  }

}
