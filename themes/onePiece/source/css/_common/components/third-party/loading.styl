#loading {
  --loading-bg: #fff;
  --loading-color: #222;
  --loading-text: rgba(0, 0, 0, .68);
  --loading-text-muted: rgba(0, 0, 0, .54);
  --loading-text-strong: rgba(0, 0, 0, .9);
  --loading-line: rgba(0, 0, 0, .2);
  --loading-dot: rgba(0, 0, 0, .5);
  --loading-shadow: rgba(0, 0, 0, .14);
  @extend $fix-fullscreen;
  align-items: center;
  background: var(--loading-bg);
  color: var(--loading-color);
  display: flex;
  justify-content: center;
  overflow: hidden;
  padding: 1.25rem;

  if(!hexo-config('loader.start')) {
    display: none;
  }

  *, *:before, *:after {
    box-sizing: border-box;
  }
}

.loading__scene {
  align-items: center;
  display: flex;
  flex-direction: column;
  position: relative;
  z-index: 1;
}

.loading__figure {
  animation: luffy-outer-bounce 1.28s cubic-bezier(.36, 0, .2, 1) infinite;
  height: 21rem;
  max-height: 52vh;
  max-width: 92vw;
  position: relative;
  transform-origin: 50% 100%;
  width: 32rem;
  will-change: transform;
}

.loading__image {
  background: transparent;
  height: 100%;
  left: 0;
  object-fit: contain;
  position: absolute;
  top: 0;
  transform-origin: 50% 100%;
  width: 100%;
  will-change: opacity, transform;
}

.loading__image--first {
  animation:
    luffy-inner-bounce 1.28s cubic-bezier(.36, 0, .2, 1) infinite,
    luffy-switch-first 2.56s linear infinite;
}

.loading__image--second {
  animation:
    luffy-inner-bounce 1.28s cubic-bezier(.36, 0, .2, 1) infinite,
    luffy-switch-second 2.56s linear infinite;
}

.loading__shadow {
  animation: luffy-shadow 1.28s cubic-bezier(.36, 0, .2, 1) infinite;
  background: var(--loading-shadow);
  border-radius: 50%;
  filter: blur(.125rem);
  height: 1rem;
  margin-top: -1.15rem;
  width: 8.25rem;
  will-change: transform, opacity;
}

.loading__text {
  align-items: center;
  color: var(--loading-text);
  display: flex;
  font-size: .95rem;
  font-weight: 800;
  gap: .16rem;
  justify-content: center;
  letter-spacing: .14em;
  line-height: 1;
  margin-top: 1.3rem;
  min-width: 7.4rem;
  padding: 0 0 .9rem;
  position: relative;
  text-align: center;

  &:before {
    animation: loading-line 1.28s ease-in-out infinite;
    background: var(--loading-line);
    border-radius: 999rem;
    content: "";
    bottom: 0;
    height: .125rem;
    left: 50%;
    position: absolute;
    transform-origin: 50% 50%;
    width: 5.5rem;
  }
}

.loading__letter {
  animation: loading-letter-wave 1.28s ease-in-out infinite;
  display: inline-block;
  transform-origin: 50% 100%;
  will-change: color, opacity, transform;

  &:nth-child(2) {
    animation-delay: .12s;
  }

  &:nth-child(3) {
    animation-delay: .24s;
  }
}

.loading__dots {
  align-items: flex-end;
  display: inline-flex;
  gap: .16rem;
  margin-left: .1rem;

  i {
    animation: loading-dot-breathe 1.28s ease-in-out infinite;
    background: var(--loading-dot);
    border-radius: 50%;
    display: block;
    height: .2rem;
    width: .2rem;
    will-change: opacity, transform;

    &:nth-child(2) {
      animation-delay: .16s;
    }

    &:nth-child(3) {
      animation-delay: .32s;
    }
  }
}

[data-theme="dark"] {
  #loading {
    --loading-bg: var(--grey-1);
    --loading-color: var(--grey-7);
    --loading-text: rgba(247, 247, 247, .72);
    --loading-text-muted: rgba(247, 247, 247, .54);
    --loading-text-strong: rgba(255, 255, 255, .92);
    --loading-line: rgba(247, 247, 247, .24);
    --loading-dot: rgba(247, 247, 247, .56);
    --loading-shadow: rgba(0, 0, 0, .44);
  }

  #loading .loading__image {
    opacity: 1;
  }
}

@keyframes luffy-outer-bounce {
  0%, 100% {
    transform: translateY(.2rem);
  }
  18% {
    transform: translateY(.12rem);
  }
  48% {
    transform: translateY(-5.2rem);
  }
  64% {
    transform: translateY(-4.7rem);
  }
  78% {
    transform: translateY(.25rem);
  }
  88% {
    transform: translateY(-.75rem);
  }
}

@keyframes luffy-inner-bounce {
  0%, 100% {
    transform: scaleX(1.14) scaleY(.86);
  }
  12% {
    transform: scaleX(.88) scaleY(1.18);
  }
  46% {
    transform: scaleX(.98) scaleY(1.04);
  }
  64% {
    transform: scaleX(1) scaleY(1);
  }
  78% {
    transform: scaleX(1.2) scaleY(.78);
  }
  88% {
    transform: scaleX(.94) scaleY(1.1);
  }
}

@keyframes luffy-switch-first {
  0%, 44% {
    opacity: 1;
  }
  50%, 94% {
    opacity: 0;
  }
  100% {
    opacity: 1;
  }
}

@keyframes luffy-switch-second {
  0%, 44% {
    opacity: 0;
  }
  50%, 94% {
    opacity: 1;
  }
  100% {
    opacity: 0;
  }
}

@keyframes luffy-shadow {
  0%, 100% {
    opacity: .32;
    transform: scaleX(1.12);
  }
  42%, 58% {
    opacity: .12;
    transform: scaleX(.62);
  }
  74% {
    opacity: .4;
    transform: scaleX(1.24);
  }
  84% {
    opacity: .22;
    transform: scaleX(.9);
  }
}

@keyframes loading-line {
  0%, 100% {
    opacity: .45;
    transform: translateX(-50%) scaleX(.66);
  }
  50% {
    opacity: 1;
    transform: translateX(-50%) scaleX(1);
  }
}

@keyframes loading-letter-wave {
  0%, 100% {
    color: var(--loading-text-muted);
    opacity: .74;
    transform: translateY(0) scale(1);
  }
  36% {
    color: var(--loading-text-strong);
    opacity: 1;
    transform: translateY(-.18rem) scale(1.04);
  }
  68% {
    transform: translateY(.04rem) scale(.99);
  }
}

@keyframes loading-dot-breathe {
  0%, 100% {
    opacity: .24;
    transform: scale(.72);
  }
  42% {
    opacity: .72;
    transform: scale(1);
  }
}

@media (max-width: 767px) {
  #loading {
    padding: .85rem;
  }

  .loading__figure {
    height: 17rem;
    max-height: 50vh;
    width: 26rem;
  }

  .loading__shadow {
    width: 6.75rem;
  }
}

@media (max-width: 413px) {
  .loading__figure {
    height: 15rem;
    width: 23rem;
  }

  .loading__text {
    font-size: .88rem;
  }
}

@media (prefers-reduced-motion: reduce) {
  .loading__figure,
  .loading__image,
  .loading__shadow,
  .loading__text:before,
  .loading__letter,
  .loading__dots i {
    animation: none;
  }

  #loading .loading__image.loading__image--first {
    opacity: 1;
  }

  #loading .loading__image.loading__image--second {
    opacity: 0;
  }
}
