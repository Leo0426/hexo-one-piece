// Menu
// --------------------------------------------------
#nav .menu {
  padding: .625rem 0;
  margin: 0;
  width: 100%;

  .item {
    display: inline-block;
    position: relative;

    padding: 0 .625rem;
    letter-spacing: .0625rem;
    text-align: center;


    +mobile() {
      display: none;

      &.title {
        display: block;
      }
    }

    .ic {
      margin-right: .5rem;
    }

    .menu__home-icon {
      background: url('../images/op-text-icons/sunny-emblem-nav.png') center / contain no-repeat;
      display: inline-block;
      filter: drop-shadow(0 .0625rem .0625rem rgba(0, 0, 0, .45));
      height: 1.45em;
      margin-right: .2rem;
      vertical-align: -.35em;
      width: 1.45em;

      &:before {
        content: '';
      }
    }

    .menu__friends-icon {
      background: url('../images/op-text-icons/going-merry.png') center / contain no-repeat;
      display: inline-block;
      filter: drop-shadow(0 .0625rem .0625rem rgba(0, 0, 0, .3));
      height: 1.35em;
      margin-right: .25rem;
      vertical-align: -.28em;
      width: 1.35em;

      &:before {
        content: '';
      }
    }

    .menu__archives-icon {
      background: url('../images/op-text-icons/log-pose.png') center / contain no-repeat;
      display: inline-block;
      filter: drop-shadow(0 .0625rem .0625rem rgba(0, 0, 0, .3));
      height: 1.32em;
      margin-right: .25rem;
      vertical-align: -.24em;
      width: 1.32em;

      &:before {
        content: '';
      }
    }

    .menu__categories-icon {
      background: url('../images/op-text-icons/poneglyph.png') center / contain no-repeat;
      display: inline-block;
      filter: drop-shadow(0 .0625rem .0625rem rgba(0, 0, 0, .28));
      height: 1.28em;
      margin-right: .25rem;
      vertical-align: -.24em;
      width: 1.28em;

      &:before {
        content: '';
      }
    }

    .menu__tags-icon {
      background: url('../images/op-text-icons/devil-fruit-round.png') center / contain no-repeat;
      display: inline-block;
      filter: drop-shadow(0 .0625rem .0625rem rgba(0, 0, 0, .28));
      height: 1.28em;
      margin-right: .25rem;
      vertical-align: -.23em;
      width: 1.28em;

      &:before {
        content: '';
      }
    }

    .menu__about-icon {
      background: url('../images/op-text-icons/straw-hat-jolly-roger.png') center / contain no-repeat;
      display: inline-block;
      filter: drop-shadow(0 .0625rem .0625rem rgba(0, 0, 0, .35));
      height: 1.3em;
      margin-right: .25rem;
      vertical-align: -.24em;
      width: 1.3em;

      &:before {
        content: '';
      }
    }

    &:not(.title) a {
      display: block;
      font-family: "Pirata One", "ZCOOL QingKe HuangYou", "ZCOOL KuaiLe", "Noto Serif SC", "PingFang SC", "Microsoft YaHei", sans-serif;
      font-size: $font-size-large;
      font-weight: 400;
      font-synthesis: none;
      letter-spacing: .03rem;
      text-shadow: 0 .0625rem .125rem rgba(0, 0, 0, .16);

      @extend $hover-underline;
    }

    &.title a {
      display: block;
      font-family: "Pirata One", "ZCOOL QingKe HuangYou", "ZCOOL KuaiLe", "Noto Serif SC", "PingFang SC", "Microsoft YaHei", sans-serif;
      font-size: 1.08rem;
      font-weight: 500;
      line-height: 1.2;
      text-shadow: 0 .0625rem .125rem rgba(0, 0, 0, .18);
    }

    &.active:not(.dropdown), &:not(.dropdown):hover {
      a::before {
        width: 70%;
      }
    }
  }

  .submenu {
    display: none;
    position: absolute;
    margin-top: .5rem;
    padding: 0;
    width: max-content;
    background-color: var(--grey-9-a5);
    box-shadow: 0 .3125rem 1.25rem -.25rem var(--grey-9-a1);
    border-radius: .625rem 0;
    @extend .slide-up-in;

    &::before {
      position: absolute;
      top: -1.25rem;
      left: 0;
      width: 100%;
      height: 2.5rem;
      content: '';
    }

    &:hover {
      display: block;
    }

    .item {
      display: block;

      &:first-child{
        border-radius: .625rem 0 0 0;
      }

      &:last-child{
        border-radius: 0 0 .625rem 0
      }

      a {
        display: inline-block;
        padding: .3rem .7rem;
        width: 100%;
        text-shadow: none;
        &::before {
          content: none;
        }
      }

      &:hover a {
        transform: translateX(.3rem);
      }

      &:hover, &.active {
        @extend $color-btn;
        a {
          opacity: 1;
        }
      }
    }
  }

  .item.dropdown {
    >a::after {
      content: "";
      display: inline-block;
      margin-left: .3rem;
      vertical-align: middle;
      border: .3rem solid transparent;
      border-top-color: currentColor;
      border-bottom: 0;
    }
    &:hover {
      .submenu {
        display: block;
      }
    }
  }
}

#nav .menu .item.title > a.menu__site-title {
  display: block;
  font-family: "Pirata One", "ZCOOL QingKe HuangYou", "ZCOOL KuaiLe", "Noto Serif SC", "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 1.08rem;
  font-weight: 400;
  font-synthesis: none;
  letter-spacing: .04rem;
  line-height: 1.2;
  text-shadow: 0 .0625rem .125rem rgba(0, 0, 0, .18);
}
