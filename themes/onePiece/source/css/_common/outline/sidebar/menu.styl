.overview .menu {
  padding: 1.25rem;
  margin: 0;

  background-color: transparent;

  .item {
    border-radius: .9375rem;
    margin-bottom: .625rem;
    display: block;
    color: var(--grey-5);
    the-transition();

    a {
      align-items: center;
      color: inherit;
      display: flex;
      font-family: "Pirata One", "ZCOOL QingKe HuangYou", "ZCOOL KuaiLe", "Noto Serif SC", "PingFang SC", "Microsoft YaHei", sans-serif;
      font-size: 1.25rem;
      font-weight: 400;
      font-synthesis: none;
      justify-content: center;
      letter-spacing: .03rem;
      line-height: 1.4;
      min-height: 3.1em;
      text-shadow: 0 .0625rem .125rem rgba(0, 0, 0, .08);
    }

    .submenu {
      display: none;
      padding: 0;
      @extend .slide-down-in;
    }

    &:hover {
      background-color: rgba(0,0,0,.1);
      color: inherit;

      .submenu {
        display: block;
      }
    }

    .ic {
      font-size: 1.1em;
      margin-right: .45rem;
    }

    .menu__home-icon {
      background: url('../images/op-text-icons/sunny-emblem.png') center / contain no-repeat;
      display: inline-block;
      flex: 0 0 auto;
      height: 1.55em;
      margin-right: .45rem;
      width: 1.55em;

      &:before {
        content: '';
      }
    }

    .menu__friends-icon {
      background: url('../images/op-text-icons/going-merry.png') center / contain no-repeat;
      display: inline-block;
      flex: 0 0 auto;
      height: 1.5em;
      margin-right: .4rem;
      width: 1.5em;

      &:before {
        content: '';
      }
    }

    .menu__archives-icon {
      background: url('../images/op-text-icons/log-pose.png') center / contain no-repeat;
      display: inline-block;
      flex: 0 0 auto;
      height: 1.45em;
      margin-right: .4rem;
      width: 1.45em;

      &:before {
        content: '';
      }
    }

    .menu__categories-icon {
      background: url('../images/op-text-icons/poneglyph.png') center / contain no-repeat;
      display: inline-block;
      flex: 0 0 auto;
      height: 1.42em;
      margin-right: .4rem;
      width: 1.42em;

      &:before {
        content: '';
      }
    }

    .menu__tags-icon {
      background: url('../images/op-text-icons/devil-fruit-round.png') center / contain no-repeat;
      display: inline-block;
      flex: 0 0 auto;
      height: 1.42em;
      margin-right: .4rem;
      width: 1.42em;

      &:before {
        content: '';
      }
    }

    .menu__about-icon {
      background: url('../images/op-text-icons/straw-hat-jolly-roger.png') center / contain no-repeat;
      display: inline-block;
      flex: 0 0 auto;
      height: 1.44em;
      margin-right: .4rem;
      width: 1.44em;

      &:before {
        content: '';
      }
    }

    &.active {
      @extend $color-btn;

      &:hover {
        box-shadow: 0 0 .75rem var(--color-pink);
        color: var(--grey-0);
      }

      .item {
        color: currentColor;
      }
    }


    &.expand {
      background-color: rgba(0,0,0,.05);

      .submenu {
        display: block;
      }

    }

  }
}
